{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["postId", "id", "name", "email", "body"],
    "properties": {
      "postId": {"type": "integer"},
      "id": {"type": "integer"},
      "name": {"type": "string"},
      "email": {"type": "string"},
      "body": {"type": "string"}
    },
    "additionalProperties": true
  }
}
