<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Properties>
    <Property name="LOG_PATTERN">%d{HH:mm:ss.SSS} %-5level [%t] %c{1} - %msg%n</Property>
  </Properties>

  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="${LOG_PATTERN}"/>
    </Console>

    <File name="File" fileName="target/logs/tests.log" append="false">
      <PatternLayout pattern="${LOG_PATTERN}"/>
    </File>
  </Appenders>

  <Loggers>
    <Logger name="com.algodatta" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="File"/>
    </Logger>

    <Logger name="org.openqa.selenium" level="WARN"/>
    <Logger name="io.restassured" level="WARN"/>

    <Root level="INFO">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="File"/>
    </Root>
  </Loggers>
</Configuration>
