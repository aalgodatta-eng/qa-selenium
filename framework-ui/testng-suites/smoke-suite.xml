<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="UITestingPlayground - Smoke Suite"
       verbose="2"
       parallel="false"
       thread-count="1">

    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="false"/>

    <listeners>
        <listener class-name="com.uitesting.listeners.TestNGListener"/>
    </listeners>

    <test name="Smoke Tests - UITestingPlayground">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.uitesting.smoke.SmokeTests"/>
        </classes>
    </test>
</suite>
